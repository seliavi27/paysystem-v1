{
    "name": "anton/paysystem-v3",
    "description": "Payment processing system on PHP",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Anton",
            "email": "anton@example.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "monolog/monolog": "^3.10",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^7.0",
        "symfony/http-foundation": "^7.4",
        "symfony/routing": "^7.4",
        "symfony/http-kernel": "^7.4",
        "symfony/config": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/filesystem": "^7.4",
        "symfony/cache": "^7.4",
        "symfony/yaml": "^7.4",
        "symfony/var-exporter": "^7.4",
        "doctrine/dbal": "^4.0",
        "doctrine/orm": "^3.6",
        "doctrine/migrations": "^3.9",
        "symfony/cache": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "twig/twig": "^3.24",
        "symfony/console": "^8.0",
        "symfony/framework-bundle": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "PaySystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaySystem\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
