{
    "name": "anton/paysystem-v2",
    "description": "Payment processing system on PHP",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Anton",
            "email": "anton@example.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "monolog/monolog": "^3.10",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^7.0",
        "symfony/http-foundation": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/config": "^8.0",
        "symfony/filesystem": "^8.0",
        "doctrine/dbal": "^4.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "PaySystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaySystem\\Tests\\": "tests/"
        }
    }
}
